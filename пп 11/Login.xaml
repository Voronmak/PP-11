<Window x:Class="пп_11.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:пп_11"
        mc:Ignorable="d"
        Title="Login" Height="320" Width="400" MaxHeight="320" MaxWidth="400" MinHeight="320" MinWidth="400">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="0.3*"/>
            <RowDefinition Height="0.5*"/>
            <RowDefinition Height="0.5*"/>
            <RowDefinition Height="0.5*"/>
            <RowDefinition Height="0.5*"/>
            <RowDefinition Height="0.7*"/>
            <RowDefinition Height="0.5*"/>
            <RowDefinition Height="0.5*"/>
        </Grid.RowDefinitions>

        <Label Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="0"
       Content="Добро пожаловать! Войдите в систему." x:Name="EnterLabel"
       VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontSize="17" Background="#FF364A52" Margin="5,5,5,5" Foreground="White" FontFamily="Georgia" FontWeight="Bold" />

        <Label Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="2"
       Content="Логин" x:Name="LoginLabel"
       VerticalContentAlignment="Bottom" HorizontalContentAlignment="Left" Foreground="#FF364A52" FontFamily="Georgia" FontWeight="Bold"/>

        <TextBox Grid.Column="0" Grid.ColumnSpan="2" 
         Grid.Row="3" x:Name="LoginTextBox" Margin="3,2,3,5" Background="White" BorderBrush="#FF4A6571" SelectionBrush="#FF5E8190" />

        <Label Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="4"
    Content="Пароль" x:Name="PasswordLabel"
         VerticalContentAlignment="Bottom" HorizontalContentAlignment="Left" Foreground="#FF364A52" FontFamily="Georgia" FontWeight="Bold"/>

        <PasswordBox Grid.Column="0" Grid.ColumnSpan="2" 
         Grid.Row="5" x:Name="LoginPasswordBox" Margin="3,2,3,5" BorderBrush="#FF4A6571" SelectionBrush="#FF5E8190" />

        <Button x:Name="LoginButton" Grid.Column="0" Grid.ColumnSpan="2"
        Grid.Row="6" Content="Войти" Margin="125,7,125,3" 
        Click="LoginButton_Click" Foreground="White" Background="#FF364A52"
        BorderBrush="#FF27363C" FontFamily="Georgia" FontWeight="Bold"/>

        <Label Grid.Column="0" Grid.Row="7"
         Content="Нет аккаунта?" x:Name="NoLoginRegisterLabel" Margin="1,1,-3,1"
         VerticalContentAlignment="Top" HorizontalContentAlignment="Right" 
         Foreground="#FF364A52" FontFamily="Georgia" FontWeight="Bold" 
         FontSize="10" />

        <Label Grid.Column="1" Grid.Row="7"
            Content="Зарегистрируйтесь" x:Name="NoRegisterLabel" Margin="-3,1,1,1"
            VerticalContentAlignment="Top" HorizontalContentAlignment="Left" 
            Foreground="#FF437E95" FontFamily="Georgia" FontWeight="Bold" 
            FontSize="10" MouseLeftButtonDown="NoLoginRegisterLabel_MouseLeftButtonDown"
            MouseEnter="NoRegisterLabel_MouseEnter" MouseLeave="NoRegisterLabel_MouseLeave"/>

        <Label Grid.Column="0" Grid.Row="8" Grid.ColumnSpan="2"
         Content="" x:Name="ErrorLabel" Margin="1,1,-3,1"
         VerticalContentAlignment="Top" HorizontalContentAlignment="Center" 
         Foreground="Red" FontFamily="Agency FB" FontWeight="Bold" 
         FontSize="10" />
    </Grid>
</Window>
