<Window x:Class="пп_11.Registration"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:пп_11"
        mc:Ignorable="d"
        Title="Registration" Height="520" Width="350" MaxHeight="520" MaxWidth="350" MinHeight="520" MinWidth="350">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="1.5*"/>
            <RowDefinition Height="0.3*"/>
            <RowDefinition Height="0.5*"/>
            <RowDefinition Height="0.5*"/>
            <RowDefinition Height="0.5*"/>
            <RowDefinition Height="0.5*"/>
            <RowDefinition Height="0.5*"/>
            <RowDefinition Height="0.5*"/>
            <RowDefinition Height="0.5*"/>
            <RowDefinition Height="0.5*"/>
            <RowDefinition Height="0.5*"/>
            <RowDefinition Height="0.5*"/>
            <RowDefinition Height="0.5*"/>
            <RowDefinition Height="0.5*"/>
            <RowDefinition Height="0.7*"/>
            <RowDefinition Height="0.5*"/>
            <RowDefinition Height="0.5*"/>
        </Grid.RowDefinitions>

        <Label Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="0"
            Content="Введите данные для регистрации." x:Name="EnterRegistrationLabel"
            VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontSize="17" 
            Background="#FF364A52" Margin="5,5,5,5" Foreground="White" FontFamily="Georgia" FontWeight="Bold" />

        <Label Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="2"
            Content="Логин" x:Name="RegistrationLabel"
             VerticalContentAlignment="Bottom" HorizontalContentAlignment="Left" 
             Foreground="#FF364A52" FontFamily="Georgia" FontWeight="Bold" FontSize="15"/>

        <TextBox Grid.Column="0" Grid.ColumnSpan="2" 
            Grid.Row="3" x:Name="RegistrationTextBox" Margin="3,2,3,5" Background="White" 
            BorderBrush="#FF4A6571" SelectionBrush="#FF5E8190" />

        <Label Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="4"
            Content="Пароль" x:Name="PasswordRegistrationLabel"
            VerticalContentAlignment="Bottom" HorizontalContentAlignment="Left" 
            Foreground="#FF364A52" FontFamily="Georgia" FontWeight="Bold" FontSize="15"/>

        <TextBox Grid.Column="0" Grid.ColumnSpan="2" 
            Grid.Row="5" x:Name="RegistrationPasswordBox" Margin="3,2,3,5" 
            BorderBrush="#FF4A6571" SelectionBrush="#FF5E8190" />

        <Label Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="6"
            Content="Дата Рождения" x:Name="DateTimeLabel"
            VerticalContentAlignment="Bottom" HorizontalContentAlignment="Left" 
            Foreground="#FF364A52" FontFamily="Georgia" FontWeight="Bold" FontSize="15"/>

        <DatePicker Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="7" 
            VerticalContentAlignment="Bottom" HorizontalContentAlignment="Left" Margin="3,0,230,0"/>

        <Label Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="8"
            Content="Роль" x:Name="RoleLabel"
            VerticalContentAlignment="Bottom" HorizontalContentAlignment="Left" 
            Foreground="#FF364A52" FontFamily="Georgia" FontWeight="Bold" FontSize="15"/>

        <ComboBox Grid.Column="0" Grid.ColumnSpan="2" 
            Grid.Row="9" x:Name="RoleComboBox" Margin="3,2,3,0" Background="White" 
            BorderBrush="#FF4A6571"/>

        <Label Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="10"
            Content="Номер телефона" x:Name="NumberLabel"
            VerticalContentAlignment="Bottom" HorizontalContentAlignment="Left" 
            Foreground="#FF364A52" FontFamily="Georgia" FontWeight="Bold" FontSize="15"/>

        <TextBox Grid.Column="0" Grid.ColumnSpan="2" 
            Grid.Row="11" x:Name="NumberTextBox" Margin="3,2,3,5" Background="White" 
            BorderBrush="#FF4A6571" SelectionBrush="#FF5E8190" />

        <Label Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="12"
            Content="Почта" x:Name="MailLabel"
            VerticalContentAlignment="Bottom" HorizontalContentAlignment="Left" 
            Foreground="#FF364A52" FontFamily="Georgia" FontWeight="Bold" FontSize="15"/>

        <TextBox Grid.Column="0" Grid.ColumnSpan="2" 
            Grid.Row="13" x:Name="MailTextBox" Margin="3,2,3,5" Background="White" 
            BorderBrush="#FF4A6571" SelectionBrush="#FF5E8190" />
        
        <Button x:Name="RegistrationButton" Grid.Column="0" Grid.ColumnSpan="2"
             Grid.Row="14" Content="Зарегистрироваться" Margin="100,3,100,3" 
             Click="RegistrationButton_Click" Foreground="White" Background="#FF364A52" BorderBrush="#FF27363C" 
                FontFamily="Georgia" FontWeight="Bold"/>

        <Label Grid.Column="0" Grid.Row="15"
            Content="Уже есть аккаунт?" x:Name="YesLoginEnterLabel" Margin="1,1,-3,1"
            VerticalContentAlignment="Top" HorizontalContentAlignment="Right"
            Foreground="#FF364A52" FontFamily="Georgia" FontWeight="Bold" FontSize="10"/>

        <Label Grid.Column="1" Grid.Row="15"
            Content="Войдите" x:Name="EnterInLofinLabel" Margin="-3,1,1,1"
            VerticalContentAlignment="Top" HorizontalContentAlignment="Left"
            Foreground="#FF437E95" FontFamily="Georgia" FontWeight="Bold" FontSize="10" 
            MouseLeftButtonDown="EnterInLofinLabel_MouseLeftButtonDown"
            MouseEnter="EnterInLofinLabel_MouseEnter" MouseLeave="EnterInLofinLabel_MouseLeave"/>

        <Label Grid.Column="0" Grid.Row="16" Grid.ColumnSpan="2"
            Content="" x:Name="ErrorRegisterLabel" Margin="1,1,-3,1"
            VerticalContentAlignment="Top" HorizontalContentAlignment="Center" 
            Foreground="Red" FontFamily="Agency FB" FontWeight="Bold" 
            FontSize="10" />
    </Grid>
</Window>
